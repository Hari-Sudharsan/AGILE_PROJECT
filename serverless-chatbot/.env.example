# .env.example
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git (it's in .gitignore)
# ─────────────────────────────────────────────────────

# ─── Environment ───
ENVIRONMENT=local
# Options: local, development, staging, production

# ─── LLM API Keys (Optional) ───
# If set, the chatbot uses OpenAI instead of rule-based logic
OPENAI_API_KEY=your_key_here

# ─── AWS Configuration ───
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_id_here
AWS_SECRET_ACCESS_KEY=your_id_here

# ─── Database ───
DB_TABLE_NAME=ChatLogs
# Only used in production (DynamoDB)

# ─── App Config ───
MODEL_VERSION=1.0.0
LOG_LEVEL=INFO
